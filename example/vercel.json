{
  "version": 2,
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "github": {
    "enabled": false
  },
  "installCommand": "node scripts/set-commit-hash.js && cd .. && npm ci --ignore-scripts",
  "buildCommand": "cd .. && npm run build && cd example && npm install --force && npm run build"
}
