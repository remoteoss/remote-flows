{
  "name": "@remoteoss/remote-flows",
  "version": "1.26.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/remoteoss/remote-flows.git"
  },
  "scripts": {
    "audit": "npm audit --audit-level=high",
    "build": "NODE_ENV=production tsup",
    "ci": "npm run build && npm run check-format && npm run check-exports && npm run lint && npm run type-check && npm run test",
    "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm --exclude-entrypoints index.css styles.css --profile node16",
    "check-format": "oxfmt --check",
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' NODE_ENV=development tsup --watch",
    "build:reset": "postcss src/styles/reset.css -o ./example/src/css/reset.css",
    "lint": "oxlint .",
    "format": "oxfmt",
    "openapi-ts": "openapi-ts && npm run format",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "coverage:extract": "tsx scripts/extract-coverage.ts",
    "prepare": "npm run build",
    "release": "tsx scripts/release.ts",
    "release:fix": "tsx scripts/release-hotfix.ts",
    "size": "tsx scripts/analyze-bundle-size.ts",
    "size:check": "tsx scripts/check-size-limits.ts",
    "size:badge": "tsx scripts/update-size-badge.ts",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./internals": {
      "import": {
        "types": "./dist/internals.d.ts",
        "default": "./dist/internals.js"
      },
      "default": "./dist/internals.js"
    },
    "./default-components": {
      "import": {
        "types": "./dist/default-components.d.ts",
        "default": "./dist/default-components.js"
      },
      "default": "./dist/default-components.js"
    },
    "./flows/*": {
      "import": {
        "types": "./dist/flows/*.d.ts",
        "import": "./dist/flows/*.js"
      },
      "default": "./dist/flows/*.js"
    },
    "./index.css": {
      "import": {
        "import": "./dist/index.css"
      },
      "default": "./dist/index.css"
    },
    "./styles": {
      "import": "./dist/styles.js",
      "default": "./dist/styles.js"
    },
    "./styles.css": {
      "import": "./dist/styles.css",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@remoteoss/remote-json-schema-form-kit": "^0.0.11",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.0",
    "fast-deep-equal": "^3.1.3",
    "lodash.capitalize": "^4.2.1",
    "lodash.groupby": "^4.6.0",
    "lodash.isnull": "^3.0.0",
    "lodash.mergewith": "^4.6.2",
    "lodash.omit": "^4.5.0",
    "lodash.omitby": "^4.6.0",
    "lucide-react": "^1.8.0",
    "postcss": "^8.5.9",
    "react-day-picker": "^9.14.0",
    "react-flagpack": "^2.0.6",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "yup": "^0.32.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@hey-api/openapi-ts": "^0.95.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/lodash.capitalize": "^4.2.9",
    "@types/lodash.groupby": "^4.6.9",
    "@types/lodash.isnull": "^3.0.9",
    "@types/lodash.mergewith": "^4.6.9",
    "@types/lodash.omit": "^4.5.9",
    "@types/lodash.omitby": "^4.6.9",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@vitest/coverage-istanbul": "^4.1.4",
    "chalk": "^5.6.2",
    "filesize": "^11.0.15",
    "glob": "^13.0.6",
    "gzip-size": "^7.0.0",
    "jsdom": "^29.0.2",
    "msw": "^2.13.3",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  }
}
